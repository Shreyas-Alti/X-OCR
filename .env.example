# X-OCR Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── LLM Provider (choose one) ────────────────────────────────────────────────

# Option A: Anthropic Claude (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5

# Option B: Ollama (local, uncomment to use)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3:1.7b

# ── LLM Mode: "anthropic" | "ollama" | "mock" ─────────────────────────────
LLM_MODE=anthropic

# ── Model Paths ──────────────────────────────────────────────────────────────
# Leave as defaults if using HuggingFace Hub models
TROCR_MODEL_NAME=microsoft/trocr-base-handwritten
TROCR_FINETUNED_PATH=models/trocr_finetuned

LAYOUTLMV3_MODEL_NAME=microsoft/layoutlmv3-base
LAYOUTLMV3_FINETUNED_PATH=models/layoutlmv3_finetuned

# ── Pipeline Flags ────────────────────────────────────────────────────────────
# Set to "true" to use lightweight mock models (no GPU required)
MOCK_MODE=false

# ── API Settings ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
REQUEST_TIMEOUT_SECONDS=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (use * for all during development)
CORS_ORIGINS=*

# ── Fusion Weights (Module 5) ────────────────────────────────────────────────
FUSION_VISUAL_WEIGHT=0.7
FUSION_CONTEXT_WEIGHT=0.3

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
